---
import BaseLayout from './BaseLayout.astro';
import ArticleGrid from '../components/ArticleGrid.astro';
import { getPublishedEntries, sortByPublishDate } from '../utils/content';
import { getSection, type ContentType } from '../utils/sections';

interface Props {
  contentType: ContentType;
}

const { contentType } = Astro.props;
const section = getSection(contentType);
const entries = sortByPublishDate(await getPublishedEntries(contentType));
---

<BaseLayout title={section.label} description={section.description}>
  <div class="container section">
    <header class="section-header">
      <p class="eyebrow">Section</p>
      <h1>{section.label}</h1>
      <p class="intro">{section.intro}</p>
    </header>

    <ArticleGrid
      entries={entries}
      emptyMessage={`New ${section.label.toLowerCase()} articles are on the way. Check back soon, or explore another section below.`}
    />
  </div>
</BaseLayout>

<style>
  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: var(--prose-max);
    margin-bottom: var(--space-8);
  }

  .section-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
  }

  .intro {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }
</style>
