---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

interface Props {
  entries: CollectionEntry<'blog'>[];
  emptyMessage?: string;
}

const { entries, emptyMessage = 'New articles are on the way.' } = Astro.props;
---

{
  entries.length > 0 ? (
    <ul class="grid">
      {entries.map((entry) => (
        <ArticleCard entry={entry} />
      ))}
    </ul>
  ) : (
    <p class="empty card">{emptyMessage}</p>
  )
}

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }

  .empty {
    padding: var(--space-6);
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }
</style>
