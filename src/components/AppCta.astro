---
interface Props {
  heading?: string;
  body?: string;
  ctaLabel?: string;
}

const {
  heading = 'Read the analysis. Then put it to work.',
  body = 'PnL App turns everything you learn here into a daily practice: tracking every trade, surfacing your behavioral patterns, and helping you close the gap between what you know and how you trade.',
  ctaLabel = 'Explore PnL App',
} = Astro.props;
---

<section class="cta card">
  <p class="eyebrow">Get PnL App</p>
  <h2>{heading}</h2>
  <p class="deck">{body}</p>
  <a href="https://pnlapp.co" class="btn btn-accent" target="_blank" rel="noopener">
    {ctaLabel}
  </a>
</section>

<style>
  .cta {
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .cta h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-text);
  }

  .cta .deck {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 40rem;
  }
</style>
