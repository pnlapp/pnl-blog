---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleGrid from '../components/ArticleGrid.astro';
import { getPublishedEntries, sortByPublishDate } from '../utils/content';

const entries = sortByPublishDate(await getPublishedEntries());
---

<BaseLayout
  title="Search"
  description="Search PnL Blog by article title, description, category, tag, or content type across News, Education, Trading Psychology, Glossary, and Research."
>
  <div class="container section search-page">
    <header class="search-header">
      <p class="eyebrow">Search</p>
      <h1>Search PnL Blog</h1>
      <p class="intro">
        Search across every article by title, topic, category, tag, or section. Everything runs
        in your browser, so results update as you type.
      </p>
    </header>

    <form class="search-form" role="search" aria-label="Site search">
      <label for="search-input">Search articles</label>
      <input
        id="search-input"
        type="search"
        name="q"
        placeholder="Try 'leverage', 'drawdown', or 'psychology'"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
      />
    </form>

    <p id="search-status" class="search-status" role="status" aria-live="polite"></p>

    <div id="search-results-wrapper">
      <ArticleGrid entries={entries} />
    </div>

    <p id="search-empty" class="empty card" hidden>
      No articles matched your search. Try a different word, or browse the sections from the
      navigation above.
    </p>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const wrapper = document.getElementById('search-results-wrapper');
  const emptyEl = document.getElementById('search-empty');
  const statusEl = document.getElementById('search-status');
  const items = Array.from(
    document.querySelectorAll<HTMLElement>('#search-results-wrapper li[data-search]')
  );

  function runFilter(rawQuery: string) {
    const query = rawQuery.trim().toLowerCase();

    if (!query) {
      items.forEach((item) => {
        item.hidden = false;
      });
      if (wrapper) wrapper.hidden = false;
      if (emptyEl) emptyEl.hidden = true;
      if (statusEl) statusEl.textContent = '';
      return;
    }

    let visibleCount = 0;
    items.forEach((item) => {
      const match = (item.dataset.search ?? '').includes(query);
      item.hidden = !match;
      if (match) visibleCount += 1;
    });

    if (wrapper) wrapper.hidden = visibleCount === 0;
    if (emptyEl) emptyEl.hidden = visibleCount > 0;
    if (statusEl) {
      statusEl.textContent =
        visibleCount === 0
          ? 'No results found.'
          : `${visibleCount} article${visibleCount === 1 ? '' : 's'} found.`;
    }
  }

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', (event) => {
    clearTimeout(debounceTimer);
    const value = (event.target as HTMLInputElement).value;
    debounceTimer = setTimeout(() => runFilter(value), 120);
  });
</script>

<style>
  .search-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .search-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: var(--prose-max);
  }

  .search-header h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-text);
  }

  .intro {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  .search-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 32rem;
  }

  .search-form label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .search-form input {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    color: var(--color-text);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
  }

  .search-form input::placeholder {
    color: var(--color-text-muted);
  }

  .search-form input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .search-status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .empty {
    padding: var(--space-6);
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }
</style>
