# Copy this file to .env for local development. .env is gitignored and must
# never be committed. See AUTOMATION.md for how this is set in production.

# Google Apps Script Web App URL that the homepage newsletter form submits
# to. Must use the PUBLIC_ prefix so Astro exposes it to client-side code,
# the form runs entirely in the browser with no backend of its own.
PUBLIC_NEWSLETTER_ENDPOINT=
